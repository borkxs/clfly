{
  "name": "@clfly/core",
  "version": "0.1.1",
  "description": "PostgREST for CLIs — filesystem command trees projected to CLI, help, completions, and MCP",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "cli-framework",
    "mcp",
    "mcp-server",
    "zod",
    "standard-schema",
    "json-schema",
    "file-based-routing",
    "openapi",
    "typescript",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borkxs/clfly.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/borkxs/clfly#readme",
  "bugs": {
    "url": "https://github.com/borkxs/clfly/issues"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@standard-schema/spec": "^1.0.0",
    "tsx": "^4.19.4",
    "yargs-parser": "^22.0.0"
  },
  "peerDependencies": {
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/yargs-parser": "^21.0.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "zod": "^4.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
