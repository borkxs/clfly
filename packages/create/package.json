{
  "name": "@clfly/create",
  "version": "0.0.3",
  "description": "Scaffold a clfly CLI (npm create clfly)",
  "type": "module",
  "bin": {
    "create-clfly": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && node -e \"import('node:fs').then(fs => fs.chmodSync('dist/index.js', 0o755))\"",
    "test": "node -e \"console.log('covered via @clfly/cli init tests')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clfly/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
